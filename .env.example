# Kelva Telegram Events Parser — environment template. Copy to .env (gitignored).

# --- Telegram delivery (S07) ---
# Dedicated bot: "Kelva Events" / @kelva_events_bot  (token lives in .env only)
# NOTE: the target user must press Start on @kelva_events_bot once, or the bot
# cannot deliver to them (Telegram blocks bot->user messages until /start).
TELEGRAM_BOT_TOKEN=            # BotFather token for @kelva_events_bot
TELEGRAM_TARGET_CHAT_ID=142068037

# --- Failure alerting via a dedicated errors bot (#4) ---
# When the SCHEDULED weekly run raises or delivers 0 events, the operator is
# alerted via this separate bot. If either var is unset, alerting is a no-op.
# The operator must press Start on @kelva_errors_bot once to receive DMs.
TELEGRAM_ERROR_BOT_TOKEN=     # BotFather token for @kelva_errors_bot
TELEGRAM_ERROR_CHAT_ID=142068037

# --- Telegram MTProto account read (S12) ---
# Account-based reader (full history, media, preview-disabled/private channels).
# api_id/api_hash from https://my.telegram.org; mint TELEGRAM_SESSION via
# `uv run --extra runtime python scripts/telethon_login.py`. If unset, the parser
# falls back to the zero-auth t.me/s preview client.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION=             # StringSession (credential — never commit)
TELETHON_MAX_MESSAGES=200
# Connect to Telegram data centers over IPv6. Set true on hosts that block DC IPv4
# (e.g. some RU clouds reach Telegram only over IPv6). Needs container IPv6 egress —
# docker-compose.yml uses network_mode: host for exactly this.
TELEGRAM_USE_IPV6=false
# Optional DC pin: overrides the IPv4 address stored in TELEGRAM_SESSION via
# session.set_dc(). Required alongside TELEGRAM_USE_IPV6 when the box blackholes the
# DC's IPv4 — set these to your account's HOME DC over IPv6. Find the home DC id by
# decoding the session; Telegram DC IPv6 addrs:
#   DC1 2001:b28:f23d:f001::a  DC2 2001:67c:4e8:f002::a  DC3 2001:b28:f23d:f003::a
#   DC4 2001:67c:4e8:f004::a   DC5 2001:b28:f23f:f005::a
TELEGRAM_DC_ID=0
TELEGRAM_DC_IP=
TELEGRAM_DC_PORT=443

# --- Yandex Foundation Models (S03) ---
YANDEX_API_KEY=               # Yandex Cloud API key (or IAM token)
YANDEX_FOLDER_ID=             # Yandex Cloud folder id
YANDEX_EXTRACT_MODEL=yandexgpt-lite/latest
YANDEX_DIGEST_MODEL=qwen3-235b-a22b-fp8    # large open model via Yandex (also: gpt-oss-120b)
YANDEX_OPENAI_BASE_URL=https://llm.api.cloud.yandex.net/v1

# --- LangSmith observability ---
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=kelva-events-parser

# --- Runtime tunables ---
EVENTS_DB_PATH=/data/seen.sqlite3
CHANNELS_CONFIG=channels.yaml
DIGEST_SCHEDULE_CRON=0 9 * * 1   # Mondays 09:00
HORIZON_DAYS=28
SCAN_DAYS=7
SEND_ON_EMPTY=true
